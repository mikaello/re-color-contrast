{
  "name": "re-color-contrast",
  "version": "1.0.0",
  "description": "Calculate color contrast of two colors, by using WCAG standard calculation.",
  "author": "mikaello",
  "license": "MIT",
  "homepage": "https://github.com/mikaello/re-color-contrast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaello/re-color-contrast.git"
  },
  "bugs": {
    "url": "https://github.com/mikaello/re-color-contrast/issues"
  },
  "keywords": [
    "rescript",
    "contrast",
    "wcag",
    "color",
    "accessibility"
  ],
  "scripts": {
    "res:build": "rescript",
    "res:dev": "rescript -w",
    "res:clean": "rescript clean",
